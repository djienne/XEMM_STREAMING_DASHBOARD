# Copy to `.env` (gitignored) and point docker-compose at your VPS SSH key on THIS machine.
# Either set an absolute host path here, or leave it unset and drop a copy at ./secrets/<your-key>.pem.
#
# Windows (Docker Desktop): use forward slashes, e.g.
#   XEMM_SSH_KEY=C:/Users/<you>/.ssh/your-vps-key.pem
# macOS / Linux:
#   XEMM_SSH_KEY=/home/<you>/.ssh/your-vps-key.pem
XEMM_SSH_KEY=./secrets/your-vps-key.pem

# Optional: your VPS host/IP, to pre-seed known_hosts for the health probe (blank = accept-new).
# XEMM_SSH_HOST=your.vps.host
